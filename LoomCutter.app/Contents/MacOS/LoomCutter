#!/bin/bash
# Launcher inside LoomCutter.app. macOS's app sandbox blocks the .app from
# directly exec'ing scripts on external volumes (EPERM, "Operation not
# permitted"). To work around it without requiring fancy code signing, we
# delegate to Terminal via /usr/bin/open — Terminal has the file-system
# permissions it needs to run our start.sh.

set -e

HERE="$(cd "$(dirname "$0")/../../.." && pwd)"

LOG_DIR="$HOME/Library/Logs/LoomCutter"
mkdir -p "$LOG_DIR"
exec >> "$LOG_DIR/launch.log" 2>&1

echo "==== $(date) launching from $HERE ===="

# `open` is a system binary at /usr/bin/open — runs outside our sandbox and
# launches the .command in Terminal.app, which has Full Disk Access by
# default on most user setups.
exec /usr/bin/open "$HERE/Launch Loom Cutter.command"
